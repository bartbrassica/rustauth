# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_DB=rustauth
POSTGRES_USER=rustauth
POSTGRES_PASSWORD=password

# ── Database & cache ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://rustauth:password@localhost:5432/rustauth
REDIS_URL=redis://localhost:6379

# ── JWT signing keys (REQUIRED) ───────────────────────────────────────────────
# Generate: task keys:gen
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
<base64-encoded-key>
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----
<base64-encoded-key>
-----END PUBLIC KEY-----"

# ── Token expiry (optional — shown are defaults) ──────────────────────────────
ACCESS_TOKEN_EXPIRY_SECONDS=900
REFRESH_TOKEN_EXPIRY_SECONDS=604800

# ── Server addresses (optional — shown are defaults) ─────────────────────────
HTTP_ADDR=0.0.0.0:3000
GRPC_ADDR=0.0.0.0:50051
